{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "opencode-tetris-battle",
  "version": "1.0.46",
  "description": "Multiplayer Tetris Battle plugin for OpenCode TUI",
  "type": "module",
  "license": "MIT",
  "author": "Lars Hagen",
  "homepage": "https://github.com/lars-hagen/opencode-tetris-battle#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lars-hagen/opencode-tetris-battle.git"
  },
  "bugs": {
    "url": "https://github.com/lars-hagen/opencode-tetris-battle/issues"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "tui",
    "tetris",
    "multiplayer",
    "convex"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test",
    "convex:dev": "convex dev",
    "convex:push": "convex dev --once",
    "install:test": "bun run scripts/install-test.ts",
    "dev:link": "bun run scripts/dev-link.ts",
    "upgrade": "node bin/cli.mjs upgrade",
    "prepack": "bun run typecheck && bun test",
    "release:patch": "bun run typecheck && bun test && npm version patch -m \"chore: release %s\" && git push && git push origin $(git describe --tags --abbrev=0)",
    "release:minor": "bun run typecheck && bun test && npm version minor -m \"chore: release %s\" && git push && git push origin $(git describe --tags --abbrev=0)",
    "release:major": "bun run typecheck && bun test && npm version major -m \"chore: release %s\" && git push && git push origin $(git describe --tags --abbrev=0)"
  },
  "bin": {
    "opencode-tetris-battle": "./bin/cli.mjs"
  },
  "files": [
    "README.md",
    "LICENSE",
    "tui.tsx",
    "tetris-battle.tsx",
    "version.ts",
    "tsconfig.json",
    "bin/cli.mjs"
  ],
  "exports": {
    ".": {
      "import": "./tui.tsx"
    },
    "./tui": {
      "import": "./tui.tsx"
    }
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "*",
    "@opentui/core": "*",
    "@opentui/solid": "*",
    "solid-js": "*"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.14.28",
    "@opentui/core": "^0.1.105",
    "@opentui/solid": "^0.1.105",
    "@types/bun": "^1.3.13",
    "solid-js": "^1.9.12",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "convex": "^1.36.1"
  }
}
